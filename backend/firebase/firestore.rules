rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isParticipant(chatId) {
      return isAuth() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }
    function notBanned() {
      return !exists(/databases/$(database)/documents/banned/$(request.auth.uid));
    }
    function validUser() {
      return isAuth() && notBanned();
    }
    function validPostData() {
      let d = request.resource.data;
      return d.keys().hasAll(['userId', 'type', 'content', 'timestamp'])
        && d.userId == request.auth.uid
        && d.type in ['THOUGHT', 'SONG', 'MOVIE', 'BOOK']
        && d.content is string
        && d.content.size() <= 2000
        && d.content.size() > 0;
    }
    function validMessageData() {
      let d = request.resource.data;
      return d.keys().hasAll(['senderId', 'content', 'type', 'timestamp'])
        && d.senderId == request.auth.uid
        && d.content is string
        && d.content.size() > 0
        && d.content.size() <= 1000;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone authenticated can read public profile
      allow read: if validUser();
      // Only owner can write own doc
      allow create: if isOwner(userId)
        && request.resource.data.id == userId
        && request.resource.data.email is string;
      allow update: if isOwner(userId)
        // Prevent changing critical fields
        && request.resource.data.id == resource.data.id
        && request.resource.data.email == resource.data.email;
      allow delete: if false; // Never delete users directly
    }

    // ── Posts ─────────────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if validUser();
      allow create: if validUser() && validPostData();
      allow update: if validUser() && (
        // Owner can edit content
        (isOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId)
        // Anyone authenticated can update likes/comments count (optimistic UI)
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'commentsCount', 'sharesCount']))
      );
      allow delete: if isOwner(resource.data.userId);

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if validUser();
        allow create: if validUser()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 500;
        allow delete: if isOwner(resource.data.userId);
        allow update: if false;
      }
    }

    // ── Chats ─────────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if validUser() && request.auth.uid in resource.data.participants;
      allow create: if validUser()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      allow update: if validUser() && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants; // can't add/remove participants
      allow delete: if false;
    }

    // ── Follows ───────────────────────────────────────────────────────────────
    match /follows/{followId} {
      allow read: if validUser();
      allow create: if validUser()
        && request.resource.data.followerId == request.auth.uid
        && followId == request.resource.data.followerId + '_' + request.resource.data.followingId
        && request.resource.data.followerId != request.resource.data.followingId;
      allow delete: if isOwner(resource.data.followerId);
      allow update: if false;
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{userId}/items/{notifId} {
      allow read: if isOwner(userId);
      allow create: if validUser();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // ── Banned list (read-only for clients) ───────────────────────────────────
    match /banned/{userId} {
      allow read: if isAuth();
      allow write: if false; // Only Firebase Admin SDK
    }

    // ── Reports ───────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow create: if validUser()
        && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if false; // Admin only
    }
  }
}
