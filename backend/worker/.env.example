# Cloudflare Worker secrets — set via: wrangler secret put <NAME>
# DO NOT commit real values. This file is documentation only.

SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# TMDB Bearer Token (from https://www.themoviedb.org/settings/api)
TMDB_API_KEY=eyJhbGciOiJIUzI1NiJ9...your_tmdb_bearer_token

# Google Books API Key (from https://console.cloud.google.com)
GOOGLE_BOOKS_API_KEY=AIzaSy...your_google_books_key

# Firebase Admin SDK service account JSON, base64-encoded
# Generate: base64 -i serviceAccountKey.json | tr -d '\n'
FIREBASE_ADMIN_KEY=base64_encoded_service_account_json_here
